Algoritmo Array

	Dimension calificaciones[5]
	Definir i como Entero
	Definir temp Como Real

	Para i <- 1 Hasta 5 Hacer
		Escribir "Ingrese la calificación ", i , ": "
		Leer temp
		calificaciones[i] <- temp

	FinPara

	Para i <- 1 Hasta 5 Hacer
		Escribir "Calificación ", i , ": ", calificaciones[i]
	FinPara
	
FinAlgoritmo